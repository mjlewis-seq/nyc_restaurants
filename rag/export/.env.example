# Copy this file to `.env` in this same directory, then fill in real values.
#
#   cp .env.example .env
#
# `.env` is listed in .gitignore and must NEVER be committed.
# `.env.example` (this file) contains no secrets and is safe to commit.

# --- RAGFlow ---
# Generate this from the RAGFlow web UI: top-right avatar -> API key
RAGFLOW_API_KEY=your-ragflow-api-key-here

# The address RAGFlow is reachable at from wherever you run these scripts.
# If RAGFlow is running in Docker Desktop on this same machine, the default
# below is usually correct.
RAGFLOW_BASE_URL=http://localhost:80

# The name of the dataset (knowledge base) inside RAGFlow to export.
RAGFLOW_DATASET_NAME=nyc_health_code

# --- Voyage AI ---
# From the Voyage AI dashboard: https://dashboard.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key-here

# Must match the model used to index the dataset in RAGFlow (indexing side
# of the asymmetric strategy), so the exported vectors live in the same
# embedding space RAGFlow used.
VOYAGE_MODEL=voyage-4-large
